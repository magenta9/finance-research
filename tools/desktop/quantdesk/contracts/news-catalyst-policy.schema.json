{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schemaVersion",
    "symbolMarketRules",
    "announcementProviderOrder",
    "providerStatus",
    "sourcePriorityWeights",
    "windowDefaults",
    "catalystCategories"
  ],
  "additionalProperties": false,
  "definitions": {
    "providerId": {
      "type": "string",
      "enum": [
        "cninfo",
        "eastmoney_notice",
        "sse_disclosure",
        "hkexnews",
        "hsi_index_notices",
        "sec_edgar",
        "sec_efts"
      ]
    },
    "providerOrder": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/providerId"
      }
    }
  },
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "symbolMarketRules": {
      "type": "object",
      "required": [
        "unknownReasonCode",
        "rules"
      ],
      "additionalProperties": false,
      "properties": {
        "unknownReasonCode": {
          "type": "string",
          "const": "market_unresolved"
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "market",
              "description"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "market": {
                "type": "string",
                "enum": [
                  "A",
                  "HK",
                  "US",
                  "unknown"
                ]
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "announcementProviderOrder": {
      "type": "object",
      "required": [
        "A",
        "HK",
        "US",
        "default"
      ],
      "additionalProperties": false,
      "properties": {
        "A": {
          "$ref": "#/definitions/providerOrder"
        },
        "HK": {
          "$ref": "#/definitions/providerOrder"
        },
        "US": {
          "$ref": "#/definitions/providerOrder"
        },
        "default": {
          "$ref": "#/definitions/providerOrder"
        }
      }
    },
    "providerStatus": {
      "type": "object",
      "required": [
        "cninfo",
        "eastmoney_notice",
        "sse_disclosure",
        "hkexnews",
        "hsi_index_notices",
        "sec_edgar",
        "sec_efts"
      ],
      "additionalProperties": false,
      "properties": {
        "cninfo": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "eastmoney_notice": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "sse_disclosure": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "hkexnews": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "hsi_index_notices": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "sec_edgar": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        },
        "sec_efts": {
          "type": "string",
          "enum": [
            "enabled",
            "planned",
            "disabled"
          ]
        }
      }
    },
    "sourcePriorityWeights": {
      "type": "object",
      "required": [
        "cninfo",
        "eastmoney_notice",
        "sse_disclosure",
        "hkexnews",
        "hsi_index_notices",
        "sec_edgar",
        "sec_efts"
      ],
      "additionalProperties": false,
      "properties": {
        "cninfo": {
          "type": "number"
        },
        "eastmoney_notice": {
          "type": "number"
        },
        "sse_disclosure": {
          "type": "number"
        },
        "hkexnews": {
          "type": "number"
        },
        "hsi_index_notices": {
          "type": "number"
        },
        "sec_edgar": {
          "type": "number"
        },
        "sec_efts": {
          "type": "number"
        }
      }
    },
    "windowDefaults": {
      "type": "object",
      "required": [
        "lookbackDays",
        "lookaheadDays"
      ],
      "additionalProperties": false,
      "properties": {
        "lookbackDays": {
          "type": "integer",
          "minimum": 1
        },
        "lookaheadDays": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "catalystCategories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "earnings_result",
          "guidance_forecast",
          "buyback",
          "dividend",
          "shareholder_meeting",
          "suspension_resumption",
          "major_transaction",
          "litigation_regulatory",
          "issuance_listing",
          "contract_order",
          "operation_update",
          "management_change",
          "other"
        ]
      }
    }
  }
}