{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "@quantdesk/shared": ["../shared/dist/index.d.ts"],
      "@quantdesk/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
